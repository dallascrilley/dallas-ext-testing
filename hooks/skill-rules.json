{
  "version": "2.0",
  "skills": {
    "agent-browser": {
      "description": "Browser automation workflow using agent-browser CLI for navigation, interaction, snapshots, and verification",
      "priority": 8,
      "triggers": {
        "keywords": ["agent-browser", "browser automation", "navigate browser", "snapshot page", "interact with page"],
        "keywordPatterns": ["\\bagent-browser\\b", "browser.*automation", "snapshot.*page", "interact.*page"],
        "pathPatterns": ["**/playwright*", "**/e2e/**"],
        "intentPatterns": [
          "(?:open|navigate|browse|interact|snapshot).*(?:page|site|app|browser)",
          "(?:use|run).*(?:agent-browser|browser automation)",
          "(?:verify|check|test).*(?:in|with).*(?:browser|agent-browser)"
        ]
      }
    },
    "webapp-testing": {
      "description": "Interactive webapp testing — navigate, snapshot, interact, verify with agent-browser",
      "priority": 7,
      "triggers": {
        "keywords": ["webapp test", "test webapp", "test ui", "test frontend", "verify ui", "test the app", "test the site"],
        "keywordPatterns": ["\\bwebapp.test", "test.*(?:ui|frontend|app|site|page)", "verify.*(?:ui|frontend|page)"],
        "intentPatterns": [
          "(?:test|verify|check).*(?:webapp|web app|frontend|ui|site|page|app)",
          "(?:open|navigate|browse).*(?:localhost|app|site).*(?:test|verify|check)",
          "(?:does|is).*(?:ui|page|app|site).*(?:work|correct|right|broken)"
        ]
      }
    },
    "find-bugs": {
      "description": "Security audit and bug finding in branch changes",
      "priority": 7,
      "triggers": {
        "keywords": ["find bugs", "security review", "audit code", "vulnerabilities", "security audit", "code audit"],
        "keywordPatterns": ["find.*bug", "security.*review", "audit.*code", "vulnerabilit", "\\bowasp\\b"],
        "intentPatterns": [
          "(?:find|look for|check for|hunt).*(?:bug|vulnerabilit|security|issue)",
          "(?:security|code).*(?:review|audit|scan)",
          "(?:review|audit|check).*(?:change|branch|diff).*(?:bug|security|issue)",
          "(?:are there).*(?:bug|vulnerabilit|security issue)"
        ]
      }
    }
  }
}
